<Page x:Class="DeskPilot.App.Views.OrganizeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="OrganizeView"
      Background="{DynamicResource BgPrimary}">

    <StackPanel Margin="24">
        <TextBlock Text="桌面整理" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>

        <Border Background="{DynamicResource BgSecondary}" CornerRadius="8" Padding="16">
            <StackPanel>
                <TextBlock x:Name="FileCountText" Text="正在扫描..."
                           FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                <ProgressBar x:Name="ScanProgress" IsIndeterminate="True"
                             Height="4" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <Button Content="生成整理计划" Margin="0,24,0,0"
                Padding="16,8" HorizontalAlignment="Left"
                Background="{DynamicResource AccentPrimary}"
                Foreground="{DynamicResource TextInverse}"
                BorderThickness="0"/>
    </StackPanel>
</Page>
