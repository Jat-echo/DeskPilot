<Page x:Class="DeskPilot.App.Views.AiOrganizeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="AiOrganizeView"
      Background="{DynamicResource BgPrimary}">

    <StackPanel Margin="24">
        <TextBlock Text="AI 整理" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>

        <TextBlock Text="输入你的整理需求" FontSize="14"
                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

        <TextBox x:Name="RequestBox" Height="100" TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Background="{DynamicResource BgTertiary}"
                 Foreground="{DynamicResource TextPrimary}"
                 Padding="12"/>

        <Button Content="生成计划" Margin="0,16,0,0"
                Padding="16,8" HorizontalAlignment="Left"
                Background="{DynamicResource AccentPrimary}"
                Foreground="{DynamicResource TextInverse}"
                BorderThickness="0"/>
    </StackPanel>
</Page>
