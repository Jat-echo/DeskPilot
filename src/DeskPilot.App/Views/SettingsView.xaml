<Page x:Class="DeskPilot.App.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="SettingsView"
      Background="{DynamicResource BgPrimary}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="600">
            <TextBlock Text="设置" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>

            <!-- AI Settings -->
            <TextBlock Text="AI Provider" FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <Border Background="{DynamicResource BgSecondary}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <CheckBox x:Name="AiEnabled" Content="启用 AI 整理"
                              Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                    <TextBlock Text="Base URL" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="AiBaseUrl" Padding="8" Margin="0,0,0,12"/>
                    <TextBlock Text="API Key" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="AiApiKey" Padding="8" Margin="0,0,0,12"/>
                    <Button Content="保存" Padding="12,6" HorizontalAlignment="Left"
                            Background="{DynamicResource AccentPrimary}"
                            Foreground="{DynamicResource TextInverse}"
                            BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Lark Settings -->
            <TextBlock Text="飞书连接" FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <Border Background="{DynamicResource BgSecondary}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock x:Name="LarkStatusText" Text="未连接"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>
                    <Button Content="连接飞书" Padding="12,6"
                            Background="{DynamicResource AccentPrimary}"
                            Foreground="{DynamicResource TextInverse}"
                            BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- Theme Settings -->
            <TextBlock Text="主题" FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <Border Background="{DynamicResource BgSecondary}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <RadioButton x:Name="ThemeLight" Content="浅色"
                                 Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <RadioButton x:Name="ThemeDark" Content="深色"
                                 Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <RadioButton x:Name="ThemeSystem" Content="跟随系统"
                                 Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <!-- Auto Start -->
            <TextBlock Text="开机自启动" FontSize="14" FontWeight="Medium"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <Border Background="{DynamicResource BgSecondary}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,24">
                <CheckBox x:Name="AutoStartCheckBox" Content="启用开机自启动"
                          Foreground="{DynamicResource TextPrimary}"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
